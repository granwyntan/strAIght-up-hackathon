**/node_modules/
frontend/.expo/
frontend/dist/
frontend/.expo-shared/
backend/.venv/
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
*.pyc

# Environment / secrets (keep examples)
**/.env*
.env.local
.env.*
**/.env
**/.env.local
**/.env.*
