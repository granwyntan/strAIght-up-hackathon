!**/.env.sample

# Local script outputs / private scripts
scripts/local/
scripts/private/
scripts/tmp/
scripts/**/.env*
scripts/**/*.local.*
scripts/**/*.secret.*

# Local data / caches
*.log
*.sqlite3
*.db
.DS_Store
backend/data/

# Key material
*.pem
*.key
*.p12
*.pfx

# Local temp folders that can break EAS packaging on Windows
.tmp-ensurepip/
tmp/
temp/
