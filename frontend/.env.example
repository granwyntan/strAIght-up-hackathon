# This file is only an example.
# The recommended local workflow is to edit backend/.env and let run-frontend.ps1
# generate frontend/.env.local automatically before Expo starts.
# Firebase values should now be defined as FIREBASE_* in backend/.env, and the startup script
# will map them into frontend/.env.local automatically for Expo.

EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
EXPO_PUBLIC_API_CANDIDATES=http://127.0.0.1:8000,http://10.0.2.2:8000,http://localhost:8000
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_APP_ID=1:1234567890:web:abcdef123456

