{
  "expo": {
    "name": "GramWIN",
    "slug": "gramwin",
    "scheme": "gramwin",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F5F1EA",
    "assetBundlePatterns": [
      "**/*"
    ],
    "androidStatusBar": {
      "backgroundColor": "#F5F1EA",
      "barStyle": "dark-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#F5F1EA",
      "barStyle": "dark-content"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "GramWIN can use the camera for future document and source capture flows.",
        "NSPhotoLibraryUsageDescription": "GramWIN can use your photos for future source and evidence uploads."
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro"
    }
  }
}
