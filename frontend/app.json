{
  "expo": {
    "name": "GramWIN",
    "slug": "gramwin",
    "scheme": "gramwin",
    "version": "1.0.0",
    "icon": "./assets/app-icons/app-icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F4F7FB",
    "plugins": [
      "expo-notifications"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "androidStatusBar": {
      "backgroundColor": "#F4F7FB",
      "barStyle": "dark-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#F4F7FB",
      "barStyle": "dark-content"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/app-icons/app-icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "GramWIN can use the camera for future document and source capture flows.",
        "NSPhotoLibraryUsageDescription": "GramWIN can use your photos for future source and evidence uploads.",
        "NSUserNotificationUsageDescription": "GramWIN sends a notification when your investigation is ready.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.greny.gramwin"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icons/app-icon.png",
        "backgroundColor": "#F4F7FB"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS"
      ],
      "package": "com.greny.gramwin"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/app-icons/favicon.png"
    },
    "splash": {
      "image": "./assets/app-icons/splash-icon.png",
      "backgroundColor": "#F4F7FB",
      "resizeMode": "contain"
    },
    "extra": {
      "eas": {
        "projectId": "0837cee1-2f01-4719-905d-ab66c4e67ffd"
      }
    }
  }
}
