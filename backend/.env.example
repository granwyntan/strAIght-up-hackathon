# Copy this file to backend/.env and fill in your values.
# This is now the main configuration file for both backend and frontend startup.

# App runtime
APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Set this to the public URL your phone/browser can actually reach.
# Local examples:
# - Android emulator: http://10.0.2.2:8000
# - Same-Wi-Fi phone:  http://YOUR_COMPUTER_IP:8000
# Production example:
# - https://api.yourdomain.com
BACKEND_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Optional frontend overrides.
# run-frontend.ps1 will generate frontend/.env.local from these values.
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
EXPO_PUBLIC_API_CANDIDATES=http://127.0.0.1:8000,http://10.0.2.2:8000,http://localhost:8000

# CORS
# Use "*" for local development, or a comma-separated list for deployed web clients.
# Example:
# CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=*

# Multi-model orchestration
# The backend can route different stages to different providers.
# Default stage routing below is:
# - Research/query planning: Gemini first
# - Source validation/extraction: DeepSeek or Gemini preferred inside the validator agent
# - Quote verification: Claude first with OpenAI as a secondary check
# - Citation auditing: Claude first
# - Scientific sentiment pass: Gemini preferred
# - Critical contradiction pass: xAI preferred
# - Final reasoning review: OpenAI first
# - Final writing/synthesis: OpenAI first
# - Consensus challenger: DeepSeek first
AGENTIC_WORKFLOW_ENABLED=true
LLM_MAX_OUTPUT_TOKENS=1200
LLM_TIMEOUT_SECONDS=12

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.2
OPENAI_RESEARCH_MODEL=gpt-5-mini
OPENAI_REASONING_MODEL=gpt-5.2
OPENAI_SYNTHESIS_MODEL=gpt-4.1
OPENAI_CITATION_AUDITOR_MODEL=gpt-5-mini

# Anthropic Claude
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_API_BASE_URL=https://api.anthropic.com/v1/messages
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_RESEARCH_MODEL=claude-sonnet-4-20250514
CLAUDE_REASONING_MODEL=claude-opus-4-1-20250805
CLAUDE_SYNTHESIS_MODEL=claude-sonnet-4-20250514
CLAUDE_CITATION_AUDITOR_MODEL=claude-sonnet-4-20250514

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-pro
GEMINI_RESEARCH_MODEL=gemini-2.5-pro
GEMINI_REASONING_MODEL=gemini-2.5-pro
GEMINI_SYNTHESIS_MODEL=gemini-2.5-flash
GEMINI_CITATION_AUDITOR_MODEL=gemini-2.5-flash

# xAI Grok
XAI_API_KEY=your_xai_api_key_here
XAI_API_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.20-reasoning
XAI_RESEARCH_MODEL=grok-4.20-reasoning
XAI_REASONING_MODEL=grok-4.20-reasoning
XAI_SYNTHESIS_MODEL=grok-4.20-reasoning
XAI_CITATION_AUDITOR_MODEL=grok-4.20-reasoning

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_RESEARCH_MODEL=deepseek-reasoner
DEEPSEEK_REASONING_MODEL=deepseek-reasoner
DEEPSEEK_SYNTHESIS_MODEL=deepseek-chat
DEEPSEEK_CITATION_AUDITOR_MODEL=deepseek-chat

# Stage routing order
# Use comma-separated provider IDs: openai, claude, gemini, xai, deepseek
RESEARCH_STAGE_PROVIDERS=gemini,openai,claude,deepseek,xai
AUDIT_STAGE_PROVIDERS=claude,openai,gemini,deepseek,xai
REASONING_STAGE_PROVIDERS=openai,xai,claude,deepseek,gemini
SYNTHESIS_STAGE_PROVIDERS=openai,claude,xai,gemini,deepseek
CONSENSUS_STAGE_PROVIDERS=deepseek,claude,openai,gemini,xai

# Search providers
# SerpAPI is used for breadth across the public web.
# Tavily is used for deeper evidence-oriented retrieval.
# The pipeline aims to retrieve roughly 20 to 70 candidate sources before filtering.
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_MAX_RESULTS=8
SERPAPI_API_KEY=your_serpapi_api_key_here
SERPAPI_ENGINE=google
SERPAPI_NUM_RESULTS=8
SEARCH_TIMEOUT_SECONDS=3

# Source tier domain lists
# Edit these lists to tune the weighting layer:
# - VERIFIED_AUTHORITIES -> weight 1.0
# - ESTABLISHED_SOURCES -> weight 0.6
# - GENERAL_SOURCES -> weight 0.1
VERIFIED_AUTHORITIES=who.int,nih.gov,cdc.gov,fda.gov,ods.od.nih.gov,nccih.nih.gov,medlineplus.gov,ncbi.nlm.nih.gov,pubmed.ncbi.nlm.nih.gov,cochrane.org,cochranelibrary.com
ESTABLISHED_SOURCES=jamanetwork.com,bmj.com,thelancet.com,nejm.org,nature.com,sciencedirect.com,springer.com,cell.com,harvard.edu,stanford.edu,mayoclinic.org,clevelandclinic.org
GENERAL_SOURCES=

# Persistence
DATABASE_PATH=backend/data/investigations.sqlite3
